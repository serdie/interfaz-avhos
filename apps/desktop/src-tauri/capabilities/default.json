{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Permisos por defecto de AVHOS — acceso al filesystem y dialog de selección de directorio",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" }
      ]
    },
    "dialog:allow-open",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save"
  ]
}
